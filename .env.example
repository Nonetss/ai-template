# OpenRouter
OPENROUTE_API_KEY=your_openrouter_api_key_here
OPENROUTE_MODEL=qwen/qwen3.5-9b
OPENROUTE_COMPACT_MODEL=qwen/qwen3.5-flash-02-23
OPENROUTE_WORKER_MODEL=qwen/qwen3.5-9b

# Logfire
LOGFIRE_SERVICE_NAME=template
LOGFIRE_SERVICE_VERSION=0.1.0
LOGFIRE_ENVIRONMENT=development
LOGFIRE_SEND_TO_LOGFIRE=false
LOGFIRE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agent

# Tavily
TAVILY_API_BASE_URL=https://api.tavily.io/v1
TAVILY_API_KEY="your_tavily_api_key_here"